# ── Variables d'environnement — Mémoires du Vietnam ──────────────────────────
# Dev local  : copier en .env.local et lancer docker compose up
# Production : configurer NEXT_PUBLIC_DIRECTUS_URL dans Vercel → Settings → Environment Variables

# URL de l'instance Directus
# Dev :  http://localhost:8055
# Prod : https://directus-vietnam.onrender.com  ← ta vraie URL Render
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
